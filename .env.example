# identity-provider env vars — template.
#
# Copy this to .env (gitignored) OR /tmp/idp-env (what `make dev-*`
# uses — wiped on reboot so you'll need to re-run `make dev-secrets`
# to regenerate KEK + CSRF). Either form is sourced via:
#
#     source /tmp/idp-env   # or: source .env && export $(cut -d= -f1 .env)
#
# Secrets (KEK, CSRF_KEY) are written by `make dev-secrets`.
# FGA IDs are printed by `idp fga init`.

# --- Postgres ---
export DATABASE_URL=postgres://idp:idp@localhost:5434/idp?sslmode=disable

# --- Secrets (generate fresh; do NOT commit real values) ---
# 32 bytes hex-encoded = 64 hex chars. `openssl rand -hex 32`.
export JWT_SIGNING_KEY_ENCRYPTION_KEY=<64-hex-chars>
export CSRF_KEY=<64-hex-chars>

# --- OpenFGA (populated by `idp fga init`) ---
export OPENFGA_API_URL=http://localhost:8081
export OPENFGA_STORE_ID=<printed-by-idp-fga-init>
export OPENFGA_AUTHORIZATION_MODEL_ID=<printed-by-idp-fga-init>
# Optional API token; local OpenFGA runs without auth.
# export OPENFGA_API_TOKEN=

# --- IdP server (serve only) ---
export ISSUER_URL=http://localhost:8080
export HTTP_ADDR=:8080
export SHUTDOWN_GRACE=15s
export LOG_LEVEL=debug
# CORS for browser OIDC clients (SPA). Leave empty in backend-only setups.
# Applies to /.well-known/*, /token, /userinfo.
# export ALLOWED_ORIGINS=http://localhost:5173

# --- Token TTLs ---
export ACCESS_TOKEN_TTL=15m
export ID_TOKEN_TTL=5m
export REFRESH_TOKEN_TTL=720h

# --- Outbox worker ---
# export OUTBOX_BATCH_SIZE=100
# export OUTBOX_POLL_INTERVAL=1s
# export OUTBOX_MAX_ATTEMPTS=5

# --- docs-api (layer 9) ---
# export HTTP_ADDR=:8083
# export TRUSTED_ISSUERS=http://localhost:8080
# export REQUIRED_AUD=localdev  # matches the client_id; see dev_workflow for context
# CORS: allow the Vite SPA dev server. Leave empty in prod behind a BFF.
# export ALLOWED_ORIGINS=http://localhost:5173
